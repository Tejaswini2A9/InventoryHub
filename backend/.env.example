DATABASE_URL=sqlite:///./inventory_db.db
ADMIN_EMAIL=admin@inventoryhub.com
ADMIN_PASSWORD=change-me

# Redis cache. The API falls back to database reads if Redis is unavailable.
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=60

# SMTP email delivery. Required for OTP email and customer order emails.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=InventoryHub
SMTP_USE_TLS=true
